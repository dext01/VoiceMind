<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="5dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="20dp"
    app:rippleColor="#1A7C4DFF">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Time row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvTime"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:letterSpacing="0.04"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvSource"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:textColor="@color/textMuted"
                android:background="@drawable/bg_pill_secondary"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:layout_marginStart="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <ImageButton
                android:id="@+id/btnDeleteEntry"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete"
                android:contentDescription="Удалить"
                android:visibility="gone"/>
        </LinearLayout>

        <!-- Preview text (2 lines max) -->
        <TextView
            android:id="@+id/tvText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.45"
            android:textColor="@color/textPrimary"
            android:maxLines="3"
            android:ellipsize="end"/>

        <!-- Tags -->
        <TextView
            android:id="@+id/tvTags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/primary"
            android:layout_marginTop="10dp"
            android:visibility="gone"/>

        <!-- Кнопки внизу карточки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Кнопка воспроизведения (только для голосовых) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlayAudio"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="▶ Слушать"
                android:textSize="12sp"
                android:paddingHorizontal="12dp"
                android:visibility="gone"
                app:rippleColor="@android:color/transparent"/>

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOpenDetail"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Читать →"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:paddingHorizontal="0dp"
                app:rippleColor="@android:color/transparent"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
